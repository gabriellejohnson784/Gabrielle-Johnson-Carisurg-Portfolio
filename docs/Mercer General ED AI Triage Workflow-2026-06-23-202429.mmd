    classDef workflow fill:#1f1f1f,stroke:#444,color:#f5f5f5,stroke-width:1px
    classDef decision fill:#ffffff,stroke:#222,color:#111,stroke-width:1px
    classDef ai fill:#eef7fb,stroke:#2b7fab,color:#111,stroke-width:1px,stroke-dasharray: 6 4
    classDef stage fill:#f4f4f4,stroke:#999,color:#111,stroke-width:1px