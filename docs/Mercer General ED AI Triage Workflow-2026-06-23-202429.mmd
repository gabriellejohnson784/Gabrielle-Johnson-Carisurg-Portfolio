flowchart TD
 subgraph S1["1. Arrival and red-flag screening"]
    direction LR
        A["Patient arrives<br><small>Walk-in / EMS / referral</small>"]
        B["Rapid red-flag screen<br><small>Nurse checks for obvious ESI 1 signs</small>"]
        C{"Obvious ESI 1?"}
        D["Immediate resus bypass<br><small>Patient sent directly to resus</small>"]
        AI1["AI 1: Resus bypass logging<br><small><b>In:</b> arrival time, red-flag reason, EMS vitals if available<br><b>Out:</b> temporary record, timestamp, resus alert<br><b>Human:</b> team treats first; clerk completes record later</small>"]
  end
 subgraph S2["2. Registration and referral information"]
    direction LR
        E["Registration<br><small>Demographics, arrival mode, arrival time</small>"]
        R{"Referral / transfer<br>documents present?"}
        R1["Attach referral / transfer info<br><small>Scan, attach, or flag as referred</small>"]
  end
 subgraph S3["3. Triage assessment"]
    direction LR
        F["Vitals + nurse triage assessment<br><small>Vitals, complaint, pain score,<br>brief history, allergies, pregnancy status</small>"]
        AI2["AI 2: Triage decision support<br><small><b>In:</b> vitals, age, complaint, pain score, referral info<br><b>Out:</b> suggested ESI, confidence, missing-data/under-triage flag<br><b>Human:</b> nurse accepts, edits, or escalates</small>"]
        T{"High-risk vitals or<br>under-triage warning?"}
        T1["Escalate priority<br><small>Move patient to higher-priority area</small>"]
  end
 subgraph S4["4. Zone placement, waiting, and re-triage"]
    direction LR
        G["Zone placement + waiting / re-triage<br><small>Re-checks and updated vitals recorded</small>"]
        AI3["AI 3: Waiting-room support<br><small><b>In:</b> ESI level, wait time, last vitals, location/status<br><b>Out:</b> overdue-wait alert, re-triage reminder, advocate alert<br><b>Human:</b> nurse reassesses; advocate updates patient/family</small>"]
  end
 subgraph S5["5. Doctor assessment and investigations"]
    direction LR
        H["Doctor assessment + investigations / referral<br><small>Assessment, test orders, physical forms,<br>specialty contact if needed</small>"]
        AI4["AI 4: Investigation / referral delay tracking<br><small><b>In:</b> test orders, referral time, form status, result status<br><b>Out:</b> delay flag, pending-task label, follow-up alert<br><b>Human:</b> doctor/charge nurse follows up</small>"]
  end
 subgraph S6["6. Disposition and exit"]
    direction LR
        I{"Disposition?"}
        AI5["AI 5: Disposition coordination<br><small><b>In:</b> disposition, bed/transport need, discharge needs, pending results<br><b>Out:</b> ward, pharmacy, transport, or follow-up alert<br><b>Human:</b> doctor confirms; nurse/clerk coordinates exit</small>"]
        J["Discharge + exit<br><small>Discharge papers, prescription,<br>counselling, follow-up</small>"]
        K["Admit / transfer + exit<br><small>Ward handover, specialist review,<br>porter, transport, or receiving facility</small>"]
  end
    A --> B
    B --> C
    C -- Yes --> D
    D -.-> AI1
    C -- No --> E
    E --> R
    R -- Yes --> R1
    R -- No --> F
    R1 --> F
    F -.-> AI2
    AI2 -.-> T
    T -- Yes --> T1
    T -- No --> G
    T1 --> G
    G -.-> AI3
    D --> H
    G --> H
    H -.-> AI4
    H --> I
    I -.-> AI5
    I -- Discharge --> J
    I -- Admit / Transfer --> K
    AI5 -.-> J & K

